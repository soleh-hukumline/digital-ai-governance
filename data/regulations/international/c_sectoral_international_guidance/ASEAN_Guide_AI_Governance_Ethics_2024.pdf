		<style id="wp-custom-css">
			/*CSS Search & Filter */
#search-filter-form-content ul{
    margin:0px;
    float:left;
		background-color:#f3f3f3;
}
#search-filter-form-content ul li{
    margin:0 10px;
    float:left;
}

#search-filter-form-content input[type="submit"]{
    float:left;
    color: #FFFFFF;
    background-color: #0060A9;
}
.elementor-kit-7 input[type="submit"]{
		color: #FFFFFF;
    background-color: #0060A9;
}

/*CSS Search 9050 Opportunity*/
div#search-filter-results-9050 p.read-more {
    display:none;
}
div#search-filter-results-9050 h3{
    margin-top:20px;
		margin-bottom:10px;
	font-size:18px;
}

div#search-filter-results-9050 ul.post-categories{
    list-style: none;
    margin: 0px;
    margin-right: 10px;
    font-size:90%;
		float:left;
}
div#search-filter-results-9050 hr{
    margin: 15px 0px;
    border: 1px solid black;
    width:100%;
}

/*CSS WP Jobs*/
article.awsm_job_openings{
	padding:0 3em !important;
}

/*CSS Result 3 grid*/
#search-results-3-grid .elementor-posts .elementor-post__title{
    font-family: "Rubik", Rubik, Arial;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.4em;
}
#search-results-3-grid .elementor-post.elementor-grid-item.hentry{
    padding:10px;
}
#search-results-3-grid .elementor-posts--thumbnail-top .elementor-post__thumbnail__link{
    margin-bottom:10px;
}


/*css collection detail*/
* {
  box-sizing: border-box;
}
.kiri {
  float: left;
  width: 65%;
  padding: 10px 15px;
}
.utama {
  float: left;
  width: 35%;
  padding: 10px 15px;
  overflow: hidden;
}

@media only screen and (max-width:800px) {
  /* For tablets: */
  .utama {
    width: 100%;
  }
  .kiri {
    width: 100%;
  }
}
@media only screen and (max-width:500px) {
  /* For mobile phones: */
  .kiri, .utama{
    width: 100%;
  }
}

/*css form 2 column */
* {
  box-sizing: border-box;
}

/* Create two equal columns that floats next to each other */
.column {
  float: left;
  width: 50%;
	padding:10px;
}

/* Clear floats after the columns */
.row:after {
  content: "";
  display: table;
  clear: both;
}
.but_submit {
  align-items: center;
  width: 100%;
	padding:10px;
	background-color:#0060a9;
	color:white;
	font-size:18px;
}
		</style>
