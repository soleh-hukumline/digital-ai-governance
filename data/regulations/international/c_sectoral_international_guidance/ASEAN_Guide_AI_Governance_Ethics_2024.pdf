                        <label><input type="checkbox" value="podcasts" name="location[]"> Podcasts</label>
                        <label><input type="checkbox" value="serial" name="location[]"> Serials</label>
                        <label><input type="checkbox" value="speeches" name="location[]"> Speeches</label>
                        <label><input type="checkbox" value="statements-meetings" name="location[]"> Statements</label>
                        <label><input type="checkbox" value="summit" name="location[]"> ASEAN Summit</label>
