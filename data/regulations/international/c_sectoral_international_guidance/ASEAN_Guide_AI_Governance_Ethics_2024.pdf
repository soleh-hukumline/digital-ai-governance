                    <div id="checkboxes1">
                        <label><input type="checkbox" value="000-asean-in-general" name="location1[]"> ASEAN in General</label>
                        <label><input type="checkbox" value="100-political-security" name="location1[]"> Political-Security</label>
                        <label><input type="checkbox" value="200-economic" name="location1[]"> Economic</label>
